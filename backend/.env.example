# Database
POSTGRES_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
POSTGRES_USER=username
POSTGRES_PASSWORD=password
POSTGRES_DB=db name

# Redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_PASSWORD= # Generate with: openssl rand -hex 32

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_TOKEN= # Generate with: openssl rand -hex 32

# Ollama
OLLAMA_URL=http://ollama:11434

# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Auth
JWT_SECRET= # Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
FREE_TIER_QUERIES_PER_MONTH=50
ALLOWED_ORIGINS=http://localhost:3000